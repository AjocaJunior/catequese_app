# Copiar este ficheiro para ".env" e preencher com os valores reais.
# NUNCA fazer commit do ficheiro ".env" (já está no .gitignore).

ENVIRONMENT=development

# String de ligação do MongoDB Atlas (cluster gratuito M0)
# Ex: mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
DB_NAME=catequese

JWT_SECRET=troca-isto-por-um-valor-secreto-longo
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# Em desenvolvimento pode deixar "*"; em produção, restringir ao domínio do Flutter Web
CORS_ORIGINS=*
